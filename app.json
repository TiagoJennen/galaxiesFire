{
  "expo": {
    "name": "galaxiesFire",
    "slug": "galaxiesFire",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.galaxiesFire",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "We gebruiken je locatie om je te waarschuwen wanneer je in de buurt bent van taken.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Je locatie is nodig om meldingen te versturen wanneer je in de buurt komt van taken, ook als de app op de achtergrond draait.",
        "NSLocationAlwaysUsageDescription": "Je locatie is nodig om meldingen te versturen wanneer je in de buurt komt van taken, ook als de app op de achtergrond draait.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "foregroundService": {
        "notificationTitle": "GalaxyFire draait op de achtergrond",
        "notificationText": "We volgen je locatie voor taakherinneringen.",
        "foregroundServiceType": "location"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.galaxiesFire",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["@maplibre/maplibre-react-native"],
    "extra": {
      "eas": {
        "projectId": "3fe5f229-24c7-4b14-9b97-8286c3064ede"
      }
    }
  }
}
